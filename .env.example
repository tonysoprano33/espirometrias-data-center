# PostgreSQL / Supabase
# Opcion recomendada si la red no soporta IPv6: Session Pooler de Supabase.
# DATABASE_URL=postgresql://postgres.[TU_PROYECTO]:[TU_PASSWORD]@[POOLER_HOST]:5432/postgres?sslmode=require
#
# El host directo db.[TU_PROYECTO].supabase.co usa IPv6 por defecto.
#
# O tambien por partes:
# DB_NAME=clinica_espiro
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_SSLMODE=require
